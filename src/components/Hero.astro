<section class="hero-container">
    <div class="hero-content">
        <div class="hero-overlay">
            <a href="#" class="btn-dark hero-btn">PARTICIPATE NOW</a>
        </div>
    </div>
</section>

<style>
    .hero-container {
        flex: 1;
        border-radius: 12px;
        overflow: hidden;
        position: relative;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
        min-height: 500px;
        background-image: url("https://images.unsplash.com/photo-1542751371-adc38448a05e?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80");
        background-size: cover;
        background-position: center;
    }

    .hero-overlay {
        position: absolute;
        bottom: 2rem;
        right: 2rem;
    }

    .hero-btn {
        font-size: 1.5rem;
        color: #fff;
        background-color: rgba(31, 41, 61, 0.9);
        border: 2px solid rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(4px);
        animation: neonPulse 2s infinite;
        transition: transform 0.3s ease;
    }
    .hero-btn:hover {
        transform: scale(1.05);
    }

    @keyframes neonPulse {
        0% {
            box-shadow: 0 0 5px rgba(255, 255, 255, 0.2);
        }
        50% {
            box-shadow: 0 0 20px rgba(255, 255, 255, 0.6);
        }
        100% {
            box-shadow: 0 0 5px rgba(255, 255, 255, 0.2);
        }
    }

    /* Reducción de animaciones para dispositivos lentos */
    :global(html.reduce-animations) .hero-btn,
    @media (prefers-reduced-motion: reduce) {
        .hero-btn {
            animation: none !important;
            transition: none !important;
        }
    }

    @media (max-width: 768px) {
        .hero-container {
            min-height: 300px;
        }
    }
</style>
