---

<section class="stats-section">
    <div class="stat-item">
        <span class="stat-label">TOURNAMENTS<br />HELD</span>
        <span class="stat-value">1213</span>
    </div>
    <div class="stat-divider"></div>
    <div class="stat-item">
        <span class="stat-label">REGISTERED<br />PLAYERS</span>
        <span class="stat-value">7098</span>
    </div>
</section>

<style>
    .stats-section {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 4rem;
        padding: 2rem;
        background-color: var(--color-card);
        border-radius: 8px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        margin-top: 2rem;
    }
    .stat-item {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }
    .stat-label {
        font-weight: bold;
        font-size: 1.5rem;
        text-align: right;
        text-transform: uppercase;
        line-height: 1.1;
    }
    .stat-value {
        font-size: 3.5rem;
        font-family: var(--font-heading);
        color: var(--color-text);
    }
    .stat-divider {
        width: 4px;
        height: 60px;
        background-color: var(--color-card);
    }

    @media (max-width: 768px) {
        .stats-section {
            flex-direction: column;
            gap: 2rem;
        }
        .stat-divider {
            display: none;
        }
        .stat-label {
            font-size: 1.2rem;
        }
        .stat-value {
            font-size: 2.5rem;
        }
    }
</style>
